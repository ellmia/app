# OpenRouter (server secret - use your free credits key)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional model override.
# Recommended for free tier: set LLM_MODEL=openrouter/free
# This lets OpenRouter automatically choose from currently available free models.
#
# Local: put in .env
# Production: npx wrangler secret put LLM_MODEL   (then enter the value: openrouter/free)
#
# If not set at all, the code default is now also "openrouter/free".

# Site (used for referer headers etc.)
PUBLIC_SITE_URL=https://chat.hostorch.workers.dev
